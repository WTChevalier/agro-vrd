{
    "name": "gurztac/auth-client",
    "description": "Cliente de autenticación contra el IdP Cuenta Gurztac. Validación JWT RS256 + SSO + middlewares Laravel.",
    "type": "library",
    "license": "proprietary",
    "authors": [
        {
            "name": "WT Chevalier",
            "email": "wt@gurztacproductions.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-openssl": "*",
        "ext-json": "*",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/cache": "^11.0|^12.0|^13.0",
        "lcobucci/jwt": "^5.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Gurztac\\AuthClient\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Gurztac\\AuthClient\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Gurztac\\AuthClient\\AuthClientServiceProvider"
            ],
            "aliases": {
                "GurztacAuth": "Gurztac\\AuthClient\\Facades\\GurztacAuth"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
